<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.s33533.ope-times-report</string>

  <key>ProgramArguments</key>
  <array>
    <string>__SCRIPT_DIR__/run.sh</string>
  </array>

  <key>WorkingDirectory</key>
  <string>__SCRIPT_DIR__</string>

  <key>StartCalendarInterval</key>
  <dict>
    <key>Day</key>
    <integer>1</integer>
    <key>Hour</key>
    <integer>10</integer>
    <key>Minute</key>
    <integer>0</integer>
  </dict>

  <key>StandardOutPath</key>
  <string>__SCRIPT_DIR__/run.log</string>
  <key>StandardErrorPath</key>
  <string>__SCRIPT_DIR__/run.log</string>

  <key>RunAtLoad</key>
  <false/>
</dict>
</plist>
